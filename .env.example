# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
BASE_URL=https://your-domain.com   # Public URL (ngrok in dev, your server in prod)

# ─── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx        # Your Twilio number
RECEPTIONIST_PHONE_NUMBER=+1xxxxxxxxxx  # Human receptionist number
DIAL_TIMEOUT_SECONDS=20                 # Seconds to ring before AI takes over

# ─── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o
WHISPER_MODEL=whisper-1

# ─── SendGrid ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=receptionist@yourcompany.com
EMAIL_FROM_NAME=AI Receptionist
RECEPTIONIST_EMAIL=receptionist@yourcompany.com

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ai_receptionist

# ─── Company ───────────────────────────────────────────────────────────────────
COMPANY_NAME=Acme Corporation
COMPANY_TIMEZONE=America/New_York

# ─── Optional: Slack Alerts ────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ─── Optional: SMS Alerts (urgent calls) ───────────────────────────────────────
ALERT_SMS_NUMBER=+1xxxxxxxxxx  # Number to SMS for urgent calls
